# DEMOCRAC.IA — Variables de entorno
# Copiar a .env y completar con valores reales

# ── LLM (requerido para Hunter Agent y generación de reportes) ────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Autenticación Protocolo de Observación ────────────────────────────────────
# Claves separadas por coma. Cambiar en producción.
OBSERVER_API_KEYS=democracia-obs-dev-2026

# ── Paths de datasets (opcionales — usa mock si no están) ────────────────────
# En Railway: subir los CSV como volumen persistente en /data/
VDEM_CSV_PATH=../data/V-Dem-CY-Full+Others-v15.csv
FH_CSV_PATH=../data/All_data_FIW_2013-2025 - Index.csv
RSF_CSV_PATH=../data/RSF/2025 - 2025.csv
PEI_CSV_PATH=../data/PEI/PEI_10 Election External.csv

# ── Alertas (opcionales) ──────────────────────────────────────────────────────
